# ---- Required / recommended for Docker & production ----

# Bind address + port (Docker defaults these if omitted)
HOST=0.0.0.0
PORT=4321

# Persist Astro DB to a file (mount /data as a volume)
# For Docker, this is a `file:` URL.
ASTRO_DB_REMOTE_URL=file:/data/wryteon.sqlite

# Optional: seed a default admin user (recommended on first deploy)
WRYTEON_ADMIN_USERNAME=admin
WRYTEON_ADMIN_EMAIL=admin@example.com
WRYTEON_ADMIN_PASSWORD=change-me
