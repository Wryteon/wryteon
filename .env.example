# ---- Required / recommended for Docker & production ----
# For local development with `npm run dev -- --remote`, use:
# ASTRO_DB_REMOTE_URL=file:./data/wryteon.sqlite
# Then run these once before starting dev:
#   mkdir -p data && touch data/wryteon.sqlite
#   npx astro db push --remote
#   npx astro db execute db/seed.ts --remote

# Bind address + port (Docker defaults these if omitted)
HOST=0.0.0.0
PORT=4321

# Disable Astro telemetry by default
ASTRO_TELEMETRY_DISABLED=1

# Persist Astro DB to a file (mount /data as a volume)
# For Docker, this is a `file:` URL inside the container.
# Do not use `/data/...` for local dev unless that absolute path exists on your machine.
ASTRO_DB_REMOTE_URL=file:/data/wryteon.sqlite

# Local data path (suggested)
# ASTRO DB_REMOTE_URL=file:./data/wryteon.sqlite

# Optional: seed a default admin user.
# For first-time local setup, run `npx astro db execute db/seed.ts --remote`
# after `npx astro db push --remote` so `/auth/login` has a user to authenticate.
WRYTEON_ADMIN_EMAIL=admin@example.com
WRYTEON_ADMIN_PASSWORD=change-me
