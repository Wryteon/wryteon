---
import {
  getPostCount,
  getPostStatusCounts,
  getSiteSettings,
} from "../../lib/db";
import AdminLayout from "../../layouts/AdminLayout.astro";
import AdminSecurityWarning from "../../admin/components/AdminSecurityWarning.astro";
import AdminNav from "../../admin/components/AdminNav.astro";

export const prerender = false;

const postCount = await getPostCount();
const postStatusCounts = await getPostStatusCounts();

const settings = await getSiteSettings();
const currentYear = new Date().getFullYear();
---

<AdminLayout>
  <html lang="en">
    <head>
      <meta charset="utf-8" />
      <meta name="viewport" content="width=device-width" />
      <title>Admin Dashboard - {settings.blogName}</title>
      <style>
        * {
          margin: 0;
          padding: 0;
          box-sizing: border-box;
        }

        body {
          font-family:
            -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
          background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
          min-height: 100vh;
          padding: 20px;
        }

        .container {
          max-width: 1200px;
          margin: 0 auto;
          display: flex;
          flex-direction: column;
          gap: 24px;
        }

        .dashboard-main {
          display: flex;
          flex-direction: column;
          gap: 28px;
        }

        .dashboard-header {
          background: white;
          border-radius: 8px;
          padding: 40px;
          box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
          text-align: center;
        }

        .dashboard-header h1 {
          font-size: 32px;
          color: #333;
          margin-bottom: 10px;
        }

        .dashboard-header p {
          color: #666;
          font-size: 16px;
        }

        .stats-grid {
          display: grid;
          grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
          gap: 20px;
        }

        .stat-card {
          background: white;
          border-radius: 8px;
          padding: 30px;
          box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
          text-align: center;
          transition: transform 0.3s;
        }

        .stat-card:hover {
          transform: translateY(-5px);
        }

        .stat-number {
          font-size: 48px;
          font-weight: bold;
          color: #667eea;
          margin-bottom: 10px;
        }

        .stat-label {
          color: #666;
          font-size: 16px;
          text-transform: uppercase;
          letter-spacing: 1px;
        }

        .footer {
          text-align: center;
          color: white;
          padding: 20px;
        }

        @media (max-width: 768px) {
          body {
            padding: 12px;
          }

          .container {
            gap: 14px;
          }

          .dashboard-main {
            gap: 16px;
          }

          .dashboard-header {
            padding: 20px;
          }

          .dashboard-header h1 {
            font-size: 24px;
          }

          .stat-card {
            padding: 24px;
          }
        }
      </style>
    </head>
    <body>
      <div class="container">
        <AdminNav activePage="dashboard" settings={settings} />

        <AdminSecurityWarning />

        <main class="dashboard-main">
          <div class="dashboard-header">
            <h1>Welcome to {settings.blogName} Admin</h1>
            <p>Manage your blog posts with our powerful block-based editor</p>
          </div>

          <section class="stats-block">
            <div class="stats-grid">
              <div class="stat-card">
                <div class="stat-number">{postCount}</div>
                <div class="stat-label">Total Posts</div>
              </div>
              <div class="stat-card">
                <div class="stat-number">{postStatusCounts.draft}</div>
                <div class="stat-label">Drafts</div>
              </div>
              <div class="stat-card">
                <div class="stat-number">{postStatusCounts.published}</div>
                <div class="stat-label">Published</div>
              </div>
            </div>
          </section>

          <div class="footer">
            <p>&copy; {currentYear} {settings.blogName}</p>
          </div>
        </main>
      </div>
    </body>
  </html>
</AdminLayout>
